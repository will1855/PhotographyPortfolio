# ── Admin auth ───────────────────────────────────────────────────────────────
# Strong password for the hidden /admin route
ADMIN_PASSWORD=change_me_to_a_strong_password

# Long random string for signing JWT admin tokens
# Generate one with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
SESSION_SECRET=change_me_to_a_long_random_string

# ── Supabase ─────────────────────────────────────────────────────────────────
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key_here

# ── Storage bucket names ─────────────────────────────────────────────────────
SUPABASE_IMAGES_BUCKET=portfolio-images
SUPABASE_THUMBS_BUCKET=portfolio-thumbs

# ── Environment ──────────────────────────────────────────────────────────────
# Set to "production" on Vercel — enables secure cookies
NODE_ENV=development
