{
  "version": 2,
  "functions": {
    "server.js": {
      "includeFiles": "{*.html,*.json}"
    }
  },
  "headers": [
    {
      "source": "/(.*)\\.(png|jpg|jpeg|webp|gif|svg|ico)",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=31536000, immutable"
        }
      ]
    },
    {
      "source": "/(.*)\\.(css|js)",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=31536000, immutable"
        }
      ]
    }
  ],
  "rewrites": [
    { "source": "/sitemap.xml", "destination": "/server.js" },
    { "source": "/", "destination": "/server.js" },
    { "source": "/about", "destination": "/server.js" },
    { "source": "/api/(.*)", "destination": "/server.js" },
    { "source": "/admin", "destination": "/server.js" },
    { "source": "/login", "destination": "/server.js" }
  ]
}
