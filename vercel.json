{
  "version": 2,
  "functions": {
    "server.js": {
      "includeFiles": "*.html, *.css, script.js, admin.js, manifest.json, logo.png"
    }
  },
  "rewrites": [
    { "source": "/", "destination": "/server.js" },
    { "source": "/about", "destination": "/server.js" },
    { "source": "/api/(.*)", "destination": "/server.js" },
    { "source": "/admin", "destination": "/server.js" },
    { "source": "/login", "destination": "/server.js" }
  ]
}
